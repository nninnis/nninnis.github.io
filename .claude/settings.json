{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/log-meeting.sh task-completed" }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/log-meeting.sh teammate-idle" }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/log-meeting.sh task-created" }
        ]
      }
    ]
  }
}
